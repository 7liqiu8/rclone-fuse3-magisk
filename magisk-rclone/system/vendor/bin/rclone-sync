#!/system/bin/sh

BASE="${RCLONEDIR:-/data/adb/modules/rclone}"

set -a
. "$BASE/env"
set +a

[ -f "$RCLONE_CONFIG_DIR/env" ] && {
  set -a
  . "$RCLONE_CONFIG_DIR/env"
  set +a
}

export PATH="$BASE/vendor/bin:$BASE/system/vendor/bin:$PATH"

if [ -z "$RCLONE_CONFIG" ]; then
  if [ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/rclone.conf" ]; then
    export RCLONE_CONFIG="$RCLONE_CONFIG_DIR/rclone.conf"
  elif [ -f "$BASE/conf/rclone.conf" ]; then
    export RCLONE_CONFIG="$BASE/conf/rclone.conf"
  fi
fi

find_bin() {
  NAME="$1"
  for BIN in \
    "$BASE/vendor/bin/$NAME" \
    "$BASE/system/vendor/bin/$NAME" \
    "$BASE/system/bin/$NAME" \
    "/vendor/bin/$NAME" \
    "/system/bin/$NAME"
  do
    [ -x "$BIN" ] && {
      echo "$BIN"
      return 0
    }
  done
  command -v "$NAME" 2>/dev/null
}

RCLONE_BIN="$(find_bin rclone)"
[ -z "$RCLONE_BIN" ] && {
  echo "Error: rclone binary not found."
  exit 1
}

[ -n "$RCLONE_RC" ] && unset RCLONE_RC

exec "$RCLONE_BIN" sync "$@"
