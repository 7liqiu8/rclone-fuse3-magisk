#!/system/bin/sh

BASE="${RCLONEDIR:-/data/adb/modules/rclone}"

set -a
. "$BASE/env"
set +a

[ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/env" ] && {
  set -a
  . "$RCLONE_CONFIG_DIR/env"
  set +a
}

export PATH="$BASE/vendor/bin:$BASE/system/vendor/bin:$PATH"

if [ -z "$RCLONE_CONFIG" ]; then
  if [ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/rclone.conf" ]; then
    export RCLONE_CONFIG="$RCLONE_CONFIG_DIR/rclone.conf"
  elif [ -f "$BASE/conf/rclone.conf" ]; then
    export RCLONE_CONFIG="$BASE/conf/rclone.conf"
  fi
fi

find_bin() {
  NAME="$1"
  for BIN in \
    "$BASE/vendor/bin/$NAME" \
    "$BASE/system/vendor/bin/$NAME" \
    "$BASE/system/bin/$NAME" \
    "/vendor/bin/$NAME" \
    "/system/bin/$NAME"
  do
    [ -x "$BIN" ] && {
      echo "$BIN"
      return 0
    }
  done
  command -v "$NAME" 2>/dev/null
}

bind_if_needed() {
  SRC="$1"
  DST="$2"

  mkdir -p "$DST" || return 1
  mount | grep -q " $DST " 2>/dev/null || mount --bind "$SRC" "$DST"
}

RCLONE_BIN="$(find_bin rclone)"
[ -z "$RCLONE_BIN" ] && {
  echo "Error: rclone binary not found."
  exit 1
}

NAME="$1"
[ -z "$NAME" ] && {
  echo "Usage: $0 <name>"
  exit 1
}

shift

MNT_DIR="/mnt/rclone-$NAME"
mkdir -p "$MNT_DIR"

nice -n 1 "$RCLONE_BIN" mount "$NAME:" "$MNT_DIR" "$@"
RC=$?

if [ "$RC" -eq 0 ]; then
  MEDIA_ENDPOINT="/data/media/0/$NAME"
  mkdir -p "$MEDIA_ENDPOINT"
  chown media_rw:media_rw "$MEDIA_ENDPOINT" 2>/dev/null

  bind_if_needed "$MNT_DIR" "$MEDIA_ENDPOINT"
  bind_if_needed "$MNT_DIR" "/mnt/pass_through/0/emulated/0/$NAME"
  bind_if_needed "$MNT_DIR" "/mnt/runtime/default/emulated/0/$NAME"
  bind_if_needed "$MNT_DIR" "/mnt/runtime/read/emulated/0/$NAME"
  bind_if_needed "$MNT_DIR" "/mnt/runtime/write/emulated/0/$NAME"
  bind_if_needed "$MNT_DIR" "/mnt/runtime/full/emulated/0/$NAME"
fi

exit "$RC"
