#!/system/bin/sh

BASE="${RCLONEDIR:-/data/adb/modules/rclone}"

set -a
. "$BASE/env"
set +a

[ -f "$RCLONE_CONFIG_DIR/env" ] && {
  set -a
  . "$RCLONE_CONFIG_DIR/env"
  set +a
}

export PATH="$BASE/vendor/bin:$BASE/system/vendor/bin:$PATH"

if [ -z "$RCLONE_CONFIG" ]; then
  if [ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/rclone.conf" ]; then
    export RCLONE_CONFIG="$RCLONE_CONFIG_DIR/rclone.conf"
  elif [ -f "$BASE/conf/rclone.conf" ]; then
    export RCLONE_CONFIG="$BASE/conf/rclone.conf"
  fi
fi

find_bin() {
  NAME="$1"
  for BIN in \
    "$BASE/vendor/bin/$NAME" \
    "$BASE/system/vendor/bin/$NAME" \
    "$BASE/system/bin/$NAME" \
    "/vendor/bin/$NAME" \
    "/system/bin/$NAME"
  do
    [ -x "$BIN" ] && {
      echo "$BIN"
      return 0
    }
  done
  command -v "$NAME" 2>/dev/null
}

RCLONE_BIN="$(find_bin rclone)"
FUSERMOUNT_BIN="$(find_bin fusermount3)"

if [ -z "$RCLONE_BIN" ]; then
  echo "Error: rclone binary not found."
  exit 1
fi

if [ -z "$FUSERMOUNT_BIN" ]; then
  echo "Error: fusermount3 binary not found."
  exit 1
fi

NAME="$1"

if [ -z "$NAME" ]; then
  echo "Usage: $0 <name>"
  echo "name: the name of the rclone remote storage and will be used as the mount point"
  echo "mounts the rclone remote storage to sdcard/<name>"
  exit 1
fi

shift

MNT_DIR="/mnt/rclone-$NAME"
mkdir -p "$MNT_DIR"

nice -n 1 "$RCLONE_BIN" mount "$NAME:" "$MNT_DIR" --daemon "$@"
RC=$?

if [ "$RC" -eq 0 ]; then
  MEDIA_ENDPOINT="/data/media/0/$NAME"
  mkdir -p "$MEDIA_ENDPOINT"
  chown media_rw:media_rw "$MEDIA_ENDPOINT" 2>/dev/null

  PASS_THROUGH="/mnt/pass_through/0/emulated/0/$NAME"
  mkdir -p "$PASS_THROUGH" || {
    echo "Failed to prepare $PASS_THROUGH"
    exit 1
  }
  mount --bind "$MNT_DIR" "$PASS_THROUGH"

  DEFAULT_BINDPOINT="/mnt/runtime/default/emulated/0/$NAME"
  mkdir -p "$DEFAULT_BINDPOINT" || {
    echo "Failed to prepare $DEFAULT_BINDPOINT"
    exit 1
  }
  mount | grep -q "$DEFAULT_BINDPOINT" || mount --bind "$MNT_DIR" "$DEFAULT_BINDPOINT"
fi

exit "$RC"
