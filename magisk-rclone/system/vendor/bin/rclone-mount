#!/system/bin/sh

BASE="${RCLONEDIR:-/data/adb/modules/rclone}"

set -a
. "$BASE/env"
set +a

[ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/env" ] && {
  set -a
  . "$RCLONE_CONFIG_DIR/env"
  set +a
}

export PATH="$BASE/vendor/bin:$BASE/system/vendor/bin:$PATH"

if [ -z "$RCLONE_CONFIG" ]; then
  if [ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/rclone.conf" ]; then
    export RCLONE_CONFIG="$RCLONE_CONFIG_DIR/rclone.conf"
  elif [ -f "$BASE/conf/rclone.conf" ]; then
    export RCLONE_CONFIG="$BASE/conf/rclone.conf"
  fi
fi

find_bin() {
  NAME="$1"
  for BIN in \
    "$BASE/vendor/bin/$NAME" \
    "$BASE/system/vendor/bin/$NAME" \
    "$BASE/system/bin/$NAME" \
    "/vendor/bin/$NAME" \
    "/system/bin/$NAME"
  do
    [ -x "$BIN" ] && {
      echo "$BIN"
      return 0
    }
  done
  command -v "$NAME" 2>/dev/null
}

RCLONE_BIN="$(find_bin rclone)"
NSENTER_BIN="$(find_bin nsenter)"

[ -z "$RCLONE_BIN" ] && {
  echo "Error: rclone binary not found."
  exit 1
}

run_in_init_mnt() {
  if [ -n "$NSENTER_BIN" ] && [ -e /proc/1/ns/mnt ]; then
    "$NSENTER_BIN" --mount=/proc/1/ns/mnt -- "$@"
  else
    "$@"
  fi
}

NAME="$1"
[ -z "$NAME" ] && {
  echo "Usage: $0 <name>"
  exit 1
}

shift

MNT_DIR="/mnt/rclone-$NAME"
run_in_init_mnt mkdir -p "$MNT_DIR" || {
  echo "Error: failed to create mount dir: $MNT_DIR"
  exit 1
}

run_in_init_mnt nice -n 1 "$RCLONE_BIN" mount "$NAME:" "$MNT_DIR" "$@"
exit $?
