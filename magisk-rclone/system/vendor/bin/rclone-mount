#!/system/bin/sh

BASE="${RCLONEDIR:-/data/adb/modules/rclone}"

set -a
. "$BASE/env"
set +a

[ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/env" ] && {
  set -a
  . "$RCLONE_CONFIG_DIR/env"
  set +a
}

export PATH="$BASE/vendor/bin:$BASE/system/vendor/bin:$PATH"

if [ -z "$RCLONE_CONFIG" ]; then
  if [ -n "$RCLONE_CONFIG_DIR" ] && [ -f "$RCLONE_CONFIG_DIR/rclone.conf" ]; then
    export RCLONE_CONFIG="$RCLONE_CONFIG_DIR/rclone.conf"
  elif [ -f "$BASE/conf/rclone.conf" ]; then
    export RCLONE_CONFIG="$BASE/conf/rclone.conf"
  fi
fi

find_bin() {
  NAME="$1"
  for BIN in \
    "$BASE/vendor/bin/$NAME" \
    "$BASE/system/vendor/bin/$NAME" \
    "$BASE/system/bin/$NAME" \
    "/vendor/bin/$NAME" \
    "/system/bin/$NAME"
  do
    [ -x "$BIN" ] && {
      echo "$BIN"
      return 0
    }
  done
  command -v "$NAME" 2>/dev/null
}

RCLONE_BIN="$(find_bin rclone)"
NSENTER_BIN="$(find_bin nsenter)"

[ -z "$RCLONE_BIN" ] && {
  echo "Error: rclone binary not found."
  exit 1
}

run_in_init_mnt() {
  if [ -n "$NSENTER_BIN" ] && [ -e /proc/1/ns/mnt ]; then
    "$NSENTER_BIN" --mount=/proc/1/ns/mnt -- "$@"
  else
    "$@"
  fi
}

is_mounted_in_init() {
  TARGET="$1"
  if [ -n "$NSENTER_BIN" ] && [ -e /proc/1/ns/mnt ]; then
    "$NSENTER_BIN" --mount=/proc/1/ns/mnt -- sh -c \
      "mount | awk -v target='$TARGET' '\$2 == \"on\" && \$3 == target { found=1 } END { exit(found ? 0 : 1) }'"
  else
    mount | awk -v target="$TARGET" '$2 == "on" && $3 == target { found=1 } END { exit(found ? 0 : 1) }'
  fi
}

bind_force() {
  SRC="$1"
  DST="$2"

  run_in_init_mnt mkdir -p "$DST" || {
    echo "Error: failed to create mount point: $DST" >&2
    return 1
  }

  if is_mounted_in_init "$DST"; then
    run_in_init_mnt umount -l "$DST" 2>/dev/null
    sleep 1
  fi

  run_in_init_mnt mount --bind "$SRC" "$DST" || {
    echo "Error: bind mount failed: $SRC -> $DST" >&2
    return 1
  }

  return 0
}

NAME="$1"
[ -z "$NAME" ] && {
  echo "Usage: $0 <name>"
  exit 1
}

shift

MNT_DIR="/mnt/rclone-$NAME"
mkdir -p "$MNT_DIR" || {
  echo "Error: failed to create mount dir: $MNT_DIR"
  exit 1
}

nice -n 1 "$RCLONE_BIN" mount "$NAME:" "$MNT_DIR" "$@"
RC=$?

if [ "$RC" -eq 0 ]; then
  run_in_init_mnt mkdir -p "/data/media/0/$NAME"
  chown media_rw:media_rw "/data/media/0/$NAME" 2>/dev/null

  for DST in \
    "/data/media/0/$NAME" \
    "/mnt/pass_through/0/emulated/0/$NAME" \
    "/mnt/runtime/default/emulated/0/$NAME" \
    "/mnt/runtime/read/emulated/0/$NAME" \
    "/mnt/runtime/write/emulated/0/$NAME" \
    "/mnt/runtime/full/emulated/0/$NAME" \
    "/mnt/user/0/emulated/0/$NAME" \
    "/storage/emulated/0/$NAME"
  do
    bind_force "$MNT_DIR" "$DST"
  done

  SDCARD_REAL="$(readlink -f /sdcard 2>/dev/null)"
  if [ -n "$SDCARD_REAL" ] && [ "$SDCARD_REAL" != "/storage/emulated/0" ]; then
    bind_force "$MNT_DIR" "$SDCARD_REAL/$NAME"
  fi
fi

exit "$RC"
